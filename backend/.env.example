# --- Option A: Vertex AI Express (recommended for this project) ---
# Get your API key from console.cloud.google.com → Vertex AI → API Keys
# Use: genai.Client(vertexai=True, api_key=...)
VERTEX_EXPRESS_API_KEY=your_vertex_express_api_key_here

# --- Option B: Vertex AI with ADC (gcloud auth application-default login) ---
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# --- Option C: AI Studio API key (limited quota on free tier) ---
# Get one at https://aistudio.google.com/apikey
# GOOGLE_API_KEY=your_ai_studio_key_here
